<table class="table table-striped" data-toggle="table">
    <thead class="thead-dark">
    <tr>
        <th data-field="path" data-sortable="true">Path</th>
        <th data-field="status" data-sortable="true">Status</th>
        <th data-field="size" data-sortable="true" data-formatter="sizeFormatter">Size</th>
        <th data-field="digest" data-sortable="true">Digest</th>
    </tr>
    </thead>
    <tbody>
    {{#folder.files}}
        <tr>
            <td>{{{ auditStatus.symbol }}} {{ relativePath }}</td>
            <td>{{{ auditStatus }}}</td>
            <td>{{ length }}</td>
            <td>{{ digestRecord.shortenedDigest }}</td>
        </tr>
    {{/folder.files}}
    </tbody>
</table>
