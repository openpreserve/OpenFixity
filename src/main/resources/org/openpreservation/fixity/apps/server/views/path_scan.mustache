<!doctype html>
<html lang="en">
<head>
{{> partials/head }}
</head>
<body>
  {{> partials/navbar }}
  <div class="container-xl">
    <h1>Scan {{ scan.id }}: {{ scan.collectionPath.root }}/</h1>
    <div class="card mb-3">
      <div class="card-header">Scan Summary</div>
      <div class="card-body">
        <p class="card-text">Status: {{ scan.status }}</p>
        <p class="card-text">Duration: {{ scan.duration }}</p>
        <p class="card-text">Scanned: {{ scan.summary.totalFiles }} Files, {{ scan.summary.formattedTotalBytes }}</p>
      </div>
    </div>
    <h2><i class="bi bi-folder-open"></i> /{{ folder.relativePath }}</h2>
    <div class="mb-3">
      {{#hasParent}}
      <a href="/scans/{{ scan.id }}/folders/{{ parentId }}/" class="btn btn-outline-secondary btn-sm me-1">
        <i class="bi bi-arrow-up"></i> ..
      </a>
      {{/hasParent}}
      {{#subfolders}}
      <a href="/scans/{{ scan.id }}/folders/{{ id }}/" class="btn btn-outline-primary btn-sm me-1">
        <i class="bi bi-folder-fill"></i> {{ name }}
      </a>
      {{/subfolders}}
    </div>
    {{> partials/tables/scan_results}}
  </div><!-- end container -->
  {{> partials/footer}}
</body>
</html>
